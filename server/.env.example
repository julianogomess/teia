# Copie para .env NA RAIZ DO REPOSITÓRIO (não em server/) e preencha.
# O .gitignore já cobre .env — nunca commite este arquivo preenchido.

# --- Anthropic (mesmas variáveis da demo) ------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# opcional: uma chave por tenant (cobrança na conta/workspace do cliente)
# ANTHROPIC_API_KEY_TEIA=sk-ant-...
# ANTHROPIC_API_KEY_ONG=sk-ant-...

# --- Banco de dados -----------------------------------------------------------
# Sem esta variável, usa SQLite local (server/teia.db) — bom para desenvolvimento.
# Com o Postgres do docker-compose (docker compose up -d na raiz):
# TEIA_DATABASE_URL=postgresql+psycopg2://teia:teia-dev@localhost:5432/teia
# Em produção, desligue a criação automática de tabelas e use alembic:
# TEIA_AUTO_CREATE_TABLES=false

# --- Segurança ------------------------------------------------------------------
# Gere com: py -c "import secrets; print(secrets.token_urlsafe(48))"
TEIA_SECRET_KEY=
# Em produção (HTTPS): TEIA_COOKIE_SECURE=true

# --- Admin inicial (usado pelo seed) ------------------------------------------
TEIA_ADMIN_EMAIL=admin@teia.org.br
TEIA_ADMIN_PASSWORD=

# --- Google OAuth (console.cloud.google.com > APIs > Credentials) --------------
# Tipo: OAuth client ID > Web application.
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
TEIA_GOOGLE_CLIENT_ID=
TEIA_GOOGLE_CLIENT_SECRET=
# TEIA_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Limites e cotas (defaults; podem ser ajustados por usuário/tenant no painel)
# TEIA_LOGIN_RATE_PER_MINUTE=10
# TEIA_CHAT_RATE_PER_MINUTE=10
# TEIA_DEFAULT_USER_DAILY_MESSAGES=100
# TEIA_DEFAULT_ORG_MONTHLY_MESSAGES=10000
# TEIA_DEFAULT_ORG_MONTHLY_COST_USD=50
